  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Spyfall Digital - Premium Social Deduction</title>\n<!-- Typography -->\n<link href=\"https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,500;0,600;1,400&amp;family=Manrope:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<!-- Icons -->\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n          darkMode: \"class\",\n          theme: {\n            extend: {\n              \"colors\": {\n                      \"secondary-fixed\": \"#dbe4e8\",\n                      \"tertiary\": \"#4f626b\",\n                      \"secondary-container\": \"#dbe4e8\",\n                      \"surface-tint\": \"#4c616c\",\n                      \"surface-variant\": \"#dbe4e7\",\n                      \"on-primary-container\": \"#40555f\",\n                      \"on-secondary-fixed\": \"#384144\",\n                      \"primary-fixed-dim\": \"#c1d8e4\",\n                      \"error-container\": \"#fe8983\",\n                      \"on-primary\": \"#f0f9ff\",\n                      \"surface-bright\": \"#f8f9fa\",\n                      \"tertiary-fixed-dim\": \"#d1e6f0\",\n                      \"secondary-dim\": \"#4c5458\",\n                      \"on-secondary-container\": \"#4a5357\",\n                      \"primary-fixed\": \"#cfe6f2\",\n                      \"surface-container\": \"#eaeff1\",\n                      \"surface-container-highest\": \"#dbe4e7\",\n                      \"primary-container\": \"#cfe6f2\",\n                      \"on-secondary-fixed-variant\": \"#545d60\",\n                      \"secondary-fixed-dim\": \"#cdd6da\",\n                      \"tertiary-fixed\": \"#dff4ff\",\n                      \"inverse-surface\": \"#0c0f10\",\n                      \"surface-container-lowest\": \"#ffffff\",\n                      \"inverse-on-surface\": \"#9b9d9e\",\n                      \"on-tertiary-fixed\": \"#384b53\",\n                      \"surface-dim\": \"#d1dce0\",\n                      \"primary-dim\": \"#40555f\",\n                      \"on-tertiary-container\": \"#4a5d66\",\n                      \"on-error-container\": \"#752121\",\n                      \"on-tertiary\": \"#f2faff\",\n                      \"on-tertiary-fixed-variant\": \"#546770\",\n                      \"tertiary-dim\": \"#43565f\",\n                      \"surface-container-low\": \"#f1f4f6\",\n                      \"on-error\": \"#fff7f6\",\n                      \"on-primary-fixed-variant\": \"#495f69\",\n                      \"surface\": \"#f8f9fa\",\n                      \"outline-variant\": \"#abb3b7\",\n                      \"on-surface-variant\": \"#586064\",\n                      \"on-background\": \"#2b3437\",\n                      \"secondary\": \"#586064\",\n                      \"primary\": \"#4c616c\",\n                      \"on-surface\": \"#2b3437\",\n                      \"on-secondary\": \"#f1fafe\",\n                      \"inverse-primary\": \"#d8effb\",\n                      \"error-dim\": \"#4e0309\",\n                      \"background\": \"#f8f9fa\",\n                      \"error\": \"#9f403d\",\n                      \"surface-container-high\": \"#e3e9ec\",\n                      \"tertiary-container\": \"#dff4ff\",\n                      \"outline\": \"#737c7f\",\n                      \"on-primary-fixed\": \"#2d424c\"\n              },\n              \"borderRadius\": {\n                      \"DEFAULT\": \"1rem\",\n                      \"lg\": \"2rem\",\n                      \"xl\": \"3rem\",\n                      \"full\": \"9999px\"\n              },\n              \"fontFamily\": {\n                      \"headline\": [\n                              \"Newsreader\"\n                      ],\n                      \"body\": [\n                              \"Manrope\"\n                      ],\n                      \"label\": [\n                              \"Manrope\"\n                      ]\n              }\n            },\n          }\n        }\n      </script>\n<style>\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.4);\n            backdrop-filter: blur(20px);\n            -webkit-backdrop-filter: blur(20px);\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;\n        }\n      </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-background selection:bg-primary-container selection:text-on-primary-container min-h-screen overflow-x-hidden relative\">\n<!-- Atmospheric Background Layers -->\n<div class=\"fixed inset-0 z-0 pointer-events-none overflow-hidden\">\n<div class=\"absolute top-[-10%] right-[-10%] w-[80%] h-[60%] rounded-full bg-primary-container opacity-30 blur-[120px]\"></div>\n<div class=\"absolute bottom-[-5%] left-[-10%] w-[70%] h-[50%] rounded-full bg-secondary-fixed opacity-40 blur-[100px]\"></div>\n</div>\n<!-- Top Navigation Anchor -->\n<nav class=\"fixed top-0 w-full z-50 bg-slate-50/80 backdrop-blur-xl flex items-center justify-between px-6 py-4 max-w-screen-xl mx-auto\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-blue-900\" data-icon=\"menu\">menu</span>\n<span class=\"text-2xl font-serif italic text-blue-900\">Spyfall Digital</span>\n</div>\n</nav>\n<main class=\"relative z-10 pt-28 px-6 pb-12 flex flex-col min-h-screen max-w-md mx-auto\">\n<!-- Hero Section -->\n<header class=\"mb-12\">\n<p class=\"font-label text-on-surface-variant text-sm tracking-[0.2em] uppercase mb-3\">Choose your mode</p>\n<h1 class=\"font-headline text-4xl leading-tight text-on-surface mb-6 font-medium\">Pick how you want to play tonight.</h1>\n<p class=\"text-on-surface-variant leading-relaxed text-lg font-light\">\n                Pass &amp; Play is fastest on one shared device. Online Rooms are for remote groups.\n            </p>\n</header>\n<!-- Primary Card (Pass & Play) -->\n<section class=\"mb-6\">\n<div class=\"glass-panel p-8 rounded-lg shadow-[0_20px_40px_rgba(76,97,108,0.06)] border border-white/40 flex flex-col items-center text-center transition-all active:scale-[0.98]\">\n<div class=\"w-16 h-16 rounded-full bg-primary-container flex items-center justify-center mb-6\">\n<span class=\"material-symbols-outlined text-on-primary-container text-4xl\" data-icon=\"transfer_within_a_station\">transfer_within_a_station</span>\n</div>\n<h2 class=\"font-headline text-2xl font-medium text-on-surface mb-2\">Pass &amp; Play</h2>\n<p class=\"font-label text-sm text-on-surface-variant mb-8\">Play locally with friends in the room.</p>\n<button class=\"w-full bg-primary py-4 px-8 rounded-full text-on-primary font-headline text-lg font-medium hover:bg-primary-dim transition-colors flex items-center justify-center gap-2\">\n<span>Start Local Session</span>\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"arrow_forward\">arrow_forward</span>\n</button>\n</div>\n</section>\n<!-- Secondary Card (Online Room) -->\n<section class=\"mb-10\">\n<div class=\"glass-panel p-6 rounded-lg shadow-[0_15px_30px_rgba(76,97,108,0.04)] border border-white/30 flex items-center gap-6 transition-all active:scale-[0.98]\">\n<div class=\"flex-shrink-0 w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-secondary-container text-2xl\" data-icon=\"public\">public</span>\n</div>\n<div class=\"flex-grow\">\n<h2 class=\"font-headline text-xl font-medium text-on-surface mb-1\">Online Room</h2>\n<p class=\"font-label text-xs tracking-wide text-on-surface-variant\">Join friends remotely via invite code.</p>\n</div>\n<button class=\"bg-surface-container-highest px-6 py-3 rounded-full text-sm font-label font-bold text-on-secondary-container hover:bg-secondary-fixed transition-colors\">\n                    Join\n                </button>\n</div>\n</section>\n<!-- Tertiary Row -->\n<section class=\"mt-auto pt-6\">\n<button class=\"w-full py-5 px-6 rounded-xl bg-surface-container-low/50 hover:bg-surface-container-high transition-all flex items-center justify-between group\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors\" data-icon=\"auto_stories\">auto_stories</span>\n<span class=\"font-label text-on-surface-variant text-sm font-medium\">Open Library</span>\n</div>\n<span class=\"material-symbols-outlined text-on-surface-variant/40\" data-icon=\"chevron_right\">chevron_right</span>\n</button>\n</section>\n</main>\n<!-- Footer -->\n<footer class=\"w-full py-12 px-6 bg-slate-50 flex flex-col items-center justify-center space-y-4\">\n<div class=\"text-sm font-serif text-blue-900\">Spyfall Digital</div>\n<div class=\"flex gap-8\">\n<a class=\"text-slate-500 font-label text-xs tracking-wider uppercase hover:text-blue-900 transition-all\" href=\"#\">Legal</a>\n<a class=\"text-slate-500 font-label text-xs tracking-wider uppercase hover:text-blue-900 transition-all\" href=\"#\">Privacy</a>\n<a class=\"text-slate-500 font-label text-xs tracking-wider uppercase hover:text-blue-900 transition-all\" href=\"#\">Support</a>\n</div>\n<p class=\"text-slate-500 font-label text-xs tracking-wider uppercase opacity-60\">© 2024 Spyfall Digital. All rights reserved.</p>\n</footer>\n</body></html>"
}
