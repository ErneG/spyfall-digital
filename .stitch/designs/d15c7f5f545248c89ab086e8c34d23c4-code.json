  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com\" rel=\"preconnect\"/>\n<link crossorigin=\"\" href=\"https://fonts.gstatic.com\" rel=\"preconnect\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Sora:wght@600&amp;family=Manrope:wght@400;500;600&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"on-tertiary-fixed\": \"#334e3c\",\n                        \"surface-container-low\": \"#f0f4f6\",\n                        \"surface-container-high\": \"#e1eaed\",\n                        \"on-error\": \"#fff7f6\",\n                        \"on-primary-container\": \"#385757\",\n                        \"on-primary-fixed-variant\": \"#426161\",\n                        \"on-tertiary-container\": \"#45604d\",\n                        \"on-surface-variant\": \"#566164\",\n                        \"inverse-primary\": \"#dbfdfc\",\n                        \"primary-fixed\": \"#c7e9e8\",\n                        \"error\": \"#9f403d\",\n                        \"tertiary\": \"#4a6552\",\n                        \"on-secondary-container\": \"#395663\",\n                        \"inverse-surface\": \"#0b0f10\",\n                        \"surface-container\": \"#e8eff1\",\n                        \"on-primary-fixed\": \"#264444\",\n                        \"error-container\": \"#fe8983\",\n                        \"primary-dim\": \"#395858\",\n                        \"on-surface\": \"#2a3437\",\n                        \"outline\": \"#727d80\",\n                        \"surface-container-highest\": \"#d9e4e8\",\n                        \"on-error-container\": \"#752121\",\n                        \"tertiary-fixed-dim\": \"#cbead1\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"on-secondary-fixed\": \"#264350\",\n                        \"surface\": \"#f8fafb\",\n                        \"on-tertiary-fixed-variant\": \"#4f6b57\",\n                        \"secondary-container\": \"#c9e7f7\",\n                        \"inverse-on-surface\": \"#9a9d9e\",\n                        \"on-primary\": \"#dcfefe\",\n                        \"on-secondary-fixed-variant\": \"#435f6d\",\n                        \"on-secondary\": \"#f3faff\",\n                        \"surface-variant\": \"#d9e4e8\",\n                        \"surface-bright\": \"#f8fafb\",\n                        \"tertiary-dim\": \"#3e5946\",\n                        \"error-dim\": \"#4e0309\",\n                        \"surface-dim\": \"#cfdce0\",\n                        \"on-tertiary\": \"#e7ffeb\",\n                        \"secondary\": \"#466370\",\n                        \"secondary-fixed\": \"#c9e7f7\",\n                        \"outline-variant\": \"#a9b4b7\",\n                        \"secondary-dim\": \"#3a5764\",\n                        \"primary\": \"#456464\",\n                        \"on-background\": \"#2a3437\",\n                        \"surface-tint\": \"#456464\",\n                        \"secondary-fixed-dim\": \"#bbd9e9\",\n                        \"tertiary-container\": \"#d9f9df\",\n                        \"primary-fixed-dim\": \"#badbda\",\n                        \"tertiary-fixed\": \"#d9f9df\",\n                        \"primary-container\": \"#c7e9e8\",\n                        \"background\": \"#f8fafb\"\n                    },\n                    borderRadius: {\n                        \"DEFAULT\": \"0.25rem\",\n                        \"lg\": \"0.5rem\",\n                        \"xl\": \"0.75rem\",\n                        \"full\": \"9999px\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Sora\", \"sans-serif\"],\n                        \"body\": [\"Manrope\", \"sans-serif\"],\n                        \"label\": [\"Manrope\", \"sans-serif\"]\n                    }\n                },\n            },\n        }\n    </script>\n<style>\n        .glass-card {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(20px);\n            -webkit-backdrop-filter: blur(20px);\n        }\n        .lithic-gradient {\n            background: linear-gradient(135deg, #456464 0%, #c7e9e8 100%);\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-surface antialiased min-h-screen flex flex-col overflow-x-hidden\">\n<!-- Background Atmospheric Motifs (Asymmetrical) -->\n<div class=\"fixed inset-0 pointer-events-none z-0\">\n<div class=\"absolute -top-[10%] -right-[20%] w-[80%] h-[60%] rounded-full opacity-20 blur-[120px]\" style=\"background: radial-gradient(circle, #c7e9e8 0%, transparent 70%);\"></div>\n<div class=\"absolute bottom-[5%] -left-[10%] w-[60%] h-[50%] rounded-full opacity-10 blur-[100px]\" style=\"background: radial-gradient(circle, #456464 0%, transparent 70%);\"></div>\n</div>\n<!-- Main Content Canvas -->\n<main class=\"relative z-10 flex-1 px-8 pt-16 pb-12 max-w-lg mx-auto w-full\">\n<!-- Logotype Header -->\n<header class=\"mb-16\">\n<h1 class=\"font-headline font-semibold tracking-[0.1em] text-primary uppercase text-sm\">\n                Spyfall Digital\n            </h1>\n</header>\n<!-- Hero Section -->\n<section class=\"mb-12\">\n<h2 class=\"text-[3.5rem] font-headline font-semibold leading-[1.1] tracking-[-0.02em] text-on-background\">\n                Choose how you want to play\n            </h2>\n</section>\n<!-- Primary Action: Pass & Play -->\n<section class=\"mb-8\">\n<button class=\"w-full text-left group transition-all duration-300\">\n<div class=\"relative overflow-hidden rounded-[2rem] p-8 min-h-[340px] flex flex-col justify-between shadow-[0_40px_40px_-15px_rgba(42,52,55,0.06)] lithic-gradient\">\n<!-- Texture Overlay -->\n<div class=\"absolute inset-0 opacity-20 mix-blend-soft-light\" data-alt=\"abstract flowing liquid metal textures with soft reflections and surgical precision depth\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDTQMOMSwiZJbCt5oVsZP7T6zenqfGi649vkYsi6Bbe2511r_v4aHLDdHmPxHn2hOI1V9K2z1LXJKHr92X-bbc0Sc255FzGQSRTna2z6RNmRJjU_UXj-As7Lmknx_Hx6Cx0kn4iaJhak_Q5H637H0RZn9jF0fzAd2Pbp4XP5ZjItM2Xwq3heL9rvA8lrrVbcRQ6csBSgtEH9yedMsr9LQJtfcYylFDXuOA76uNz-OTl8SvjNf5sALIAIQCvCHG3sj74ot61FyWf__Jl'); background-size: cover;\">\n</div>\n<div class=\"relative z-10\">\n<div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 backdrop-blur-md text-white text-[10px] font-semibold uppercase tracking-widest mb-6\">\n<span class=\"material-symbols-outlined text-[14px]\">group</span>\n                            Local Session\n                        </div>\n<h3 class=\"text-3xl font-headline font-semibold text-white mb-4\">Pass &amp; Play</h3>\n<p class=\"text-white/80 text-lg leading-relaxed max-w-[260px]\">\n                            One shared device. Private handoff moments. Gather your circle and let the whispers begin.\n                        </p>\n</div>\n<div class=\"relative z-10 self-end\">\n<div class=\"w-14 h-14 rounded-full bg-white flex items-center justify-center text-primary shadow-lg group-hover:scale-110 transition-transform duration-300\">\n<span class=\"material-symbols-outlined text-3xl\">arrow_forward</span>\n</div>\n</div>\n</div>\n</button>\n</section>\n<!-- Secondary Action: Online Room -->\n<section class=\"mb-8\">\n<button class=\"w-full text-left group\">\n<div class=\"glass-card rounded-[2rem] p-6 flex items-center gap-6 shadow-[0_20px_40px_-10px_rgba(42,52,55,0.04)] border border-white/40\">\n<div class=\"w-20 h-20 rounded-2xl bg-surface-container flex items-center justify-center text-secondary\">\n<span class=\"material-symbols-outlined text-4xl\">public</span>\n</div>\n<div class=\"flex-1\">\n<h4 class=\"text-xl font-headline font-semibold text-on-surface\">Online Room</h4>\n<p class=\"text-on-surface-variant text-sm mt-1\">Connect with agents across the digital web.</p>\n</div>\n<div class=\"text-outline-variant group-hover:translate-x-1 transition-transform\">\n<span class=\"material-symbols-outlined\">chevron_right</span>\n</div>\n</div>\n</button>\n</section>\n<!-- Tertiary Action: Intel Repository -->\n<section class=\"mt-12 flex justify-center\">\n<button class=\"group flex flex-col items-center gap-3\">\n<div class=\"w-12 h-12 rounded-full flex items-center justify-center text-outline-variant border border-outline-variant/10 group-hover:bg-surface-container-low transition-colors\">\n<span class=\"material-symbols-outlined\">database</span>\n</div>\n<span class=\"text-[0.65rem] font-label font-semibold uppercase tracking-[0.15em] text-outline\">Intel Repository</span>\n<!-- Hover Underline (Tertiary style) -->\n<div class=\"h-[2px] w-0 bg-primary group-hover:w-full transition-all duration-300\"></div>\n</button>\n</section>\n<!-- Aesthetic Spacer -->\n<div class=\"h-16\"></div>\n</main>\n<!-- Visual Layering Element (Bottom right asymmetry) -->\n<div class=\"fixed bottom-0 right-0 w-32 h-32 opacity-10 pointer-events-none\">\n<div class=\"w-full h-full glass-card rounded-tl-[4rem]\"></div>\n</div>\n</body></html>"
}
