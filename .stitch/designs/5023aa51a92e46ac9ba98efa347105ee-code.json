  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Spyfall Digital - Pass &amp; Play Setup</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        brand: {\n                            muted: '#7A9FB2',\n                            graphite: '#1A1C1E',\n                            smoke: '#F1F3F5',\n                            frost: '#F8FAFB'\n                        }\n                    },\n                    borderRadius: {\n                        \"DEFAULT\": \"1rem\",\n                        \"lg\": \"2rem\",\n                        \"xl\": \"3rem\",\n                        \"full\": \"9999px\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Sora\", \"sans-serif\"],\n                        \"body\": [\"Manrope\", \"sans-serif\"],\n                        \"label\": [\"Manrope\", \"sans-serif\"]\n                    }\n                },\n            },\n        }\n    </script>\n<style>\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.4);\n            backdrop-filter: blur(12px);\n            -webkit-backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-brand-frost text-brand-graphite font-body antialiased selection:bg-brand-muted/30\">\n<!-- Top App Bar (Shared Component Anchor) -->\n<header class=\"fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-white/40 dark:bg-slate-900/40 backdrop-blur-md border-b border-white/20 dark:border-slate-800/50\">\n<button class=\"w-10 h-10 flex items-center justify-center rounded-full hover:bg-white/20 transition-colors\">\n<span class=\"material-symbols-outlined text-slate-800 dark:text-slate-100\">arrow_back</span>\n</button>\n<h1 class=\"text-lg font-bold tracking-[0.2em] text-slate-900 dark:text-white uppercase\">SPYFALL</h1>\n<button class=\"w-10 h-10 flex items-center justify-center rounded-full hover:bg-white/20 transition-colors\">\n<span class=\"material-symbols-outlined text-slate-800 dark:text-slate-100\">settings</span>\n</button>\n</header>\n<main class=\"pt-24 pb-32 px-6 max-w-md mx-auto\">\n<!-- Introduction -->\n<section class=\"mb-10 text-center\">\n<span class=\"text-brand-muted font-label uppercase tracking-widest text-[11px] font-bold\">Pass &amp; Play</span>\n<h2 class=\"font-headline text-3xl font-extrabold text-brand-graphite mt-3 leading-tight tracking-tight\">Set the round before anyone starts peeking.</h2>\n<p class=\"text-brand-muted text-sm mt-4 font-medium leading-relaxed max-w-[280px] mx-auto\">\n                Players, round settings, source selection, and the location list are visible before the game starts.\n            </p>\n</section>\n<div class=\"space-y-8\">\n<!-- 1. Players Section -->\n<section>\n<div class=\"flex justify-between items-end mb-4 px-2\">\n<h3 class=\"font-headline text-lg font-bold\">Players</h3>\n<span class=\"text-xs font-bold text-brand-muted bg-white px-2 py-1 rounded-md shadow-sm border border-brand-smoke\">5 Total</span>\n</div>\n<div class=\"space-y-3\">\n<!-- Player Row -->\n<div class=\"glass-panel rounded-2xl p-4 flex items-center justify-between shadow-sm group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-brand-muted/10 rounded-full flex items-center justify-center text-brand-muted\">\n<span class=\"material-symbols-outlined\">person</span>\n</div>\n<span class=\"font-semibold text-brand-graphite\">Alex</span>\n</div>\n<span class=\"material-symbols-outlined text-slate-300\">drag_handle</span>\n</div>\n<!-- Player Row -->\n<div class=\"glass-panel rounded-2xl p-4 flex items-center justify-between shadow-sm\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-brand-muted/10 rounded-full flex items-center justify-center text-brand-muted\">\n<span class=\"material-symbols-outlined\">person</span>\n</div>\n<span class=\"font-semibold text-brand-graphite\">Jordan</span>\n</div>\n<span class=\"material-symbols-outlined text-slate-300\">drag_handle</span>\n</div>\n<!-- Add Player Button -->\n<button class=\"w-full border-2 border-dashed border-slate-200 rounded-2xl py-4 flex items-center justify-center gap-2 text-brand-muted hover:bg-white/50 transition-colors\">\n<span class=\"material-symbols-outlined\">add</span>\n<span class=\"font-bold text-sm uppercase tracking-wider\">Add Player</span>\n</button>\n</div>\n</section>\n<!-- 2. Round Settings Section -->\n<section>\n<h3 class=\"font-headline text-lg font-bold mb-4 px-2\">Round Settings</h3>\n<div class=\"grid grid-cols-2 gap-4\">\n<div class=\"glass-panel rounded-2xl p-5 flex flex-col items-center justify-center text-center\">\n<span class=\"text-[10px] font-bold text-brand-muted uppercase tracking-widest mb-3\">Time Limit</span>\n<div class=\"flex items-center gap-4\">\n<span class=\"text-2xl font-headline font-bold\">8:00</span>\n</div>\n<div class=\"flex gap-4 mt-3\">\n<button class=\"w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center border border-brand-smoke text-brand-muted\"><span class=\"material-symbols-outlined scale-75\">remove</span></button>\n<button class=\"w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center border border-brand-smoke text-brand-muted\"><span class=\"material-symbols-outlined scale-75\">add</span></button>\n</div>\n</div>\n<div class=\"glass-panel rounded-2xl p-5 flex flex-col items-center justify-center text-center\">\n<span class=\"text-[10px] font-bold text-brand-muted uppercase tracking-widest mb-3\">Spy Count</span>\n<div class=\"flex items-center gap-4\">\n<span class=\"text-2xl font-headline font-bold\">1</span>\n</div>\n<div class=\"flex gap-4 mt-3\">\n<button class=\"w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center border border-brand-smoke text-brand-muted\"><span class=\"material-symbols-outlined scale-75\">remove</span></button>\n<button class=\"w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center border border-brand-smoke text-brand-muted\"><span class=\"material-symbols-outlined scale-75\">add</span></button>\n</div>\n</div>\n</div>\n</section>\n<!-- 3. Location Source Section -->\n<section>\n<div class=\"bg-brand-smoke p-1.5 rounded-full flex gap-1 mb-6\">\n<button class=\"flex-1 bg-white shadow-sm rounded-full py-3 text-sm font-bold text-brand-graphite tracking-tight\">Built-in Catalog</button>\n<button class=\"flex-1 py-3 text-sm font-bold text-brand-muted tracking-tight\">Saved Collection</button>\n</div>\n</section>\n<!-- 4. Included Locations Section -->\n<section>\n<div class=\"flex justify-between items-end mb-4 px-2\">\n<h3 class=\"font-headline text-lg font-bold\">Included Locations</h3>\n<button class=\"text-xs font-bold text-brand-muted border-b border-brand-muted/30\">Edit List</button>\n</div>\n<div class=\"glass-panel rounded-3xl overflow-hidden shadow-sm\">\n<div class=\"divide-y divide-white/40\">\n<div class=\"p-4 flex items-center justify-between\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-12 h-12 rounded-xl overflow-hidden bg-slate-200\">\n<img class=\"w-full h-full object-cover\" data-alt=\"serene tropical beach with turquoise water and white sand under bright clear sky\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDvs_0WHTPYu9iGFdGv7WYPUHZJDwPKPLtxfmTH0cWW3uwPWThr7TomOtNwUULvuejIIrfLfpBhMBoC8_McysIQwRls4S_cSweOQ412HhtcrZdAWgTDuE5WVUiCy9GBYGEHftpNdrM9Rq2aV5N7SdVI8wSJ8xpqoR8LBjWEhzORa447NP1Hfw8BU5NFImbqLjMeFjE1JoziIvdji7Vv9u_9tA-XJwQU1ITbj6i7H1iWwJbxKrSmWtoFa9DW-NSrKFmzuTcq5RQCAt01\"/>\n</div>\n<div>\n<h4 class=\"font-bold text-sm\">The Beach</h4>\n<span class=\"text-[10px] text-brand-muted uppercase font-bold\">12 Roles Available</span>\n</div>\n</div>\n<span class=\"material-symbols-outlined text-brand-muted/40\">check_circle</span>\n</div>\n<div class=\"p-4 flex items-center justify-between\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-12 h-12 rounded-xl overflow-hidden bg-slate-200\">\n<img class=\"w-full h-full object-cover\" data-alt=\"stately neoclassical embassy building with flags and grand architectural details at twilight\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuC0fM8e6CjhKtJ4DHh583dnOIan-qLYwkhAKxDNavD1jcRgZuna2hqoX3ZZ0CJpvsG9gaNlDJNu-XGhZF11dYTPGVjL8gkqpTg1G36FJRMYL0SXwD6ayn3Amv6fXeB5j1iB7SDFvNwD_vif3aUmQt1q_nT4ZTG-KhzXESmildnWPVZcHUZY4FtS-5T90q-m7x3PxL-sJ03I06JCzv8ABTyYqa7X4jXa9SeeRppVuHBu5q3NsitpcEhd6ru7e2H4zyL2ds1I_Xjwg59B\"/>\n</div>\n<div>\n<h4 class=\"font-bold text-sm\">The Embassy</h4>\n<span class=\"text-[10px] text-brand-muted uppercase font-bold\">8 Roles Available</span>\n</div>\n</div>\n<span class=\"material-symbols-outlined text-brand-muted/40\">check_circle</span>\n</div>\n<div class=\"p-4 flex items-center justify-between\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-12 h-12 rounded-xl overflow-hidden bg-slate-200\">\n<img class=\"w-full h-full object-cover\" data-alt=\"luxurious casino floor with dramatic lighting gold accents and velvet textures\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBDyJYNdjEFrELAFCZcIpA3euzzNGu-pNVPahrPqlmd4PRMGrSUyJZRNH1he2DX8C-fv4VBKR_qPxeuY1xbOWh0gr36jzWPFlPdcqes68FJ2ZmT3PRhTgRJEK8UKbytGAupDy9ChbjILryLvFsEUw2DFPQKawMGN5ZdAAdpu_VQCGi2jk6WTfD8k8KP5uoZsUx7zqnErBsxo4N0_4dgnlwXsr7Y11o9ar66C0vkmGVp5yn0BgP5aRxBkfEWtkA21QiJs9x3Zmxe0nz5\"/>\n</div>\n<div>\n<h4 class=\"font-bold text-sm\">Casino</h4>\n<span class=\"text-[10px] text-brand-muted uppercase font-bold\">10 Roles Available</span>\n</div>\n</div>\n<span class=\"material-symbols-outlined text-brand-muted/40\">check_circle</span>\n</div>\n</div>\n</div>\n</section>\n</div>\n<!-- Footer Actions -->\n<div class=\"fixed bottom-0 left-0 w-full p-6 pt-0 bg-gradient-to-t from-brand-frost via-brand-frost to-transparent\">\n<div class=\"max-w-md mx-auto space-y-4\">\n<button class=\"w-full bg-brand-graphite text-white rounded-2xl py-5 font-headline font-bold text-lg shadow-xl shadow-brand-graphite/20 active:scale-[0.98] transition-transform\">\n                    Start round\n                </button>\n<button class=\"w-full text-brand-muted font-bold text-sm tracking-wide uppercase py-2\">\n                    Back\n                </button>\n</div>\n</div>\n</main>\n<!-- Bottom Nav Suppression Logic: This screen is focused, so global navigation is hidden as per instructions -->\n</body></html>"
}
