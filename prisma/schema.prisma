generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── BetterAuth ──────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  displayName   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      AuthSession[]
  accounts      Account[]
  players       Player[]
  nameHistory   NameHistory[]
  collections   LocationCollection[]
}

model AuthSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Name History ────────────────────────────────────────────

model NameHistory {
  id     String   @id @default(cuid())
  userId String
  name   String
  usedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

// ─── Location Collections (per user) ─────────────────────────

model LocationCollection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations CollectionLocation[]

  @@index([userId])
}

model CollectionLocation {
  id           String  @id @default(cuid())
  collectionId String
  name         String
  allSpies     Boolean @default(false)

  collection LocationCollection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  roles      CollectionLocationRole[]

  @@index([collectionId])
}

model CollectionLocationRole {
  id                   String @id @default(cuid())
  name                 String
  collectionLocationId String

  collectionLocation CollectionLocation @relation(fields: [collectionLocationId], references: [id], onDelete: Cascade)

  @@index([collectionLocationId])
}

// ─── Game Room ───────────────────────────────────────────────

model Room {
  id             String    @id @default(cuid())
  code           String    @unique @db.VarChar(6)
  state          GameState @default(LOBBY)
  hostId         String
  timeLimit      Int       @default(480) // seconds (360-600)
  spyCount       Int       @default(1)   // 1 or 2
  autoStartTimer Boolean   @default(false)
  hideSpyCount   Boolean   @default(false)
  moderatorMode  Boolean   @default(false)
  moderatorLocationId String? // host-chosen location (null = random)
  prevLocationId String?   // last game's location (avoid repeats)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  players          Player[]
  games            Game[]
  selectedLocations RoomLocation[]
  customLocations  CustomLocation[]

  @@index([code])
}

enum GameState {
  LOBBY
  PLAYING
  VOTING
  REVEAL
  FINISHED
}

// ─── Room ↔ Location selection (which locations are enabled) ─

model RoomLocation {
  id         String @id @default(cuid())
  roomId     String
  locationId String

  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([roomId, locationId])
  @@index([roomId])
}

// ─── Custom Locations (per room) ─────────────────────────────

model CustomLocation {
  id        String  @id @default(cuid())
  roomId    String
  name      String
  allSpies  Boolean @default(false) // all-spies mode
  selected  Boolean @default(true)

  room  Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roles CustomLocationRole[]

  @@index([roomId])
}

model CustomLocationRole {
  id               String @id @default(cuid())
  name             String
  customLocationId String

  customLocation CustomLocation @relation(fields: [customLocationId], references: [id], onDelete: Cascade)

  @@index([customLocationId])
}

// ─── Player ──────────────────────────────────────────────────

model Player {
  id             String  @id @default(cuid())
  name           String
  avatarUrl      String?
  isHost         Boolean @default(false)
  isOnline       Boolean @default(true)
  moderatorRole  String? // pre-assigned role in moderator mode
  roomId         String
  userId         String? // optional link to authenticated user
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  room        Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignments Assignment[]
  votes       Vote[]       @relation("voter")
  votesAgainst Vote[]      @relation("suspect")

  @@index([roomId])
}

// ─── Game (one round within a room) ──────────────────────────

model Game {
  id            String    @id @default(cuid())
  roomId        String
  locationId    String?   // null for all-spies custom location
  locationName  String    // denormalized for custom locations
  state         GameState @default(PLAYING)
  timerRunning  Boolean   @default(true)
  timerPausedAt DateTime? // when paused, store the remaining time calc point
  startedAt     DateTime  @default(now())
  endedAt       DateTime?

  room        Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  location    Location?    @relation(fields: [locationId], references: [id])
  assignments Assignment[]
  votes       Vote[]

  @@index([roomId])
}

// ─── Assignment (player role in a game) ──────────────────────

model Assignment {
  id       String  @id @default(cuid())
  gameId   String
  playerId String
  role     String  // role name at the location, or "SPY"
  isSpy    Boolean @default(false)

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
}

// ─── Vote ────────────────────────────────────────────────────

model Vote {
  id        String   @id @default(cuid())
  gameId    String
  voterId   String
  suspectId String
  createdAt DateTime @default(now())

  game    Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  voter   Player @relation("voter", fields: [voterId], references: [id], onDelete: Cascade)
  suspect Player @relation("suspect", fields: [suspectId], references: [id], onDelete: Cascade)

  @@unique([gameId, voterId])
}

// ─── Location & Roles ────────────────────────────────────────

model Location {
  id       String @id @default(cuid())
  name     String @unique
  imageUrl String?
  edition  Int    @default(1) // 1 = classic, 2 = spyfall 2

  roles         Role[]
  games         Game[]
  roomLocations RoomLocation[]
}

model Role {
  id         String @id @default(cuid())
  name       String
  locationId String

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}
